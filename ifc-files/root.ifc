  #41 = IFCLOCALPLACEMENT(#31,#42);
  #42 = IFCAXIS2PLACEMENT3D(#43,#13,#14);
  #43 = IFCCARTESIANPOINT((0.,0.,0.));

  // --------------------------------------------------
