ISO-10303-21;
HEADER;
  FILE_DESCRIPTION(('ViewDefinition [CoordinationView]'),'2;1');
  FILE_NAME('Baugrundmodell.ifc','2025-02-06T12:00:00',('User'),('Org'),'','Copilot IFC Generator','');
  FILE_SCHEMA(('IFC4X3'));
END_HEADER;

DATA;

  // --------------------------------------------------
  // Basis: OwnerHistory, Person, Org
  // --------------------------------------------------
  #1 = IFCPERSON($,'Mustermann','Max',$,$,$,$,$);
  #2 = IFCORGANIZATION($,'Beispiel Ingenieure',$,$,$);
