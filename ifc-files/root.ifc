  #4 = IFCAPPLICATION(#2,'1.0','Copilot IFC Generator','COPILOT_APP');
  #5 = IFCOWNERHISTORY(#3,#4,$,.ADDED.,$,$,$,1675680000);

  // --------------------------------------------------
  // Geometrie-Kontext
  // --------------------------------------------------
  #10 = IFCGEOMETRICREPRESENTATIONCONTEXT($,'Model',3,1.E-5,#11,$);
  #11 = IFCAXIS2PLACEMENT3D(#12,#13,#14);
  #12 = IFCCARTESIANPOINT((0.,0.,0.));
  #13 = IFCDIRECTION((0.,0.,1.));
  #14 = IFCDIRECTION((1.,0.,0.));

  // --------------------------------------------------
  // Projekt, Site, Facility
  // --------------------------------------------------
  #20 = IFCPROJECT('3hJk2zFf9BPe$1',#5,'Baugrundmodell',$,$,$,$,(#10));
  #30 = IFCSITE('2kLm9zFf9BPe$2',#5,'Baufeld A',$,$,#31,$,$,.ELEMENT.,$,$);
  #31 = IFCLOCALPLACEMENT($,#11);

