  #51 = IFCLOCALPLACEMENT(#41,#52);
  #52 = IFCAXIS2PLACEMENT3D(#53,#13,#14);
  #53 = IFCCARTESIANPOINT((10.,5.,0.)); // Lage der Bohrung im Modell

  // --------------------------------------------------
