  #108 = IFCSHAPEREPRESENTATION(#10,'Body','SweptSolid',(#103,#107));
  #109 = IFCPRODUCTDEFINITIONSHAPE($,$,(#108));
  #96 = #109;
  #95.Representation = #109;

  // --------------------------------------------------
  // BoreholeRecord 3 – Ton (4.8–8.0 m)
  // --------------------------------------------------
  #120 = IFCBOHOLERECORD('BR01_3',#5,'4.8–8.0m Ton',4.8,8.0);

  #121 = IFCFACILITYPART('FP01_3',#5,'BH01_Schicht_3',$,$,#122,$,$);
  #122 = IFCLOCALPLACEMENT(#51,#123);
  #123 = IFCAXIS2PLACEMENT3D(#124,#13,#14);
  #124 = IFCCARTESIANPOINT((0.,0.,0.));

  #125 = IFCGEOTECHNICALSTRATUM('ST01_3',#5,'BH01_Ton',$,$,#126,$,$);

  // Geometrie 1: Bohrzylinder (4.8–8.0 m → Höhe 3.2 m, Start bei z=4.8)
  #130 = IFCAXIS2PLACEMENT3D(#131,#13,#14);
  #131 = IFCCARTESIANPOINT((0.,0.,4.8));
  #132 = IFCCIRCLEPROFILEDEF(.AREA.,$,#130,0.1);
  #133 = IFCEXTRUDEDAREASOLID(#132,#130,#73,3.2);

  // Geometrie 2: Ausbreitungsvolumen (Rechteck 4x4 m, Höhe 3.2 m)
  #134 = IFCAXIS2PLACEMENT3D(#135,#13,#14);
  #135 = IFCCARTESIANPOINT((0.,0.,4.8));
  #136 = IFCRECTANGLEPROFILEDEF(.AREA.,$,#134,4.0,4.0);
  #137 = IFCEXTRUDEDAREASOLID(#136,#134,#73,3.2);

  #138 = IFCSHAPEREPRESENTATION(#10,'Body','SweptSolid',(#133,#137));
  #139 = IFCPRODUCTDEFINITIONSHAPE($,$,(#138));
  #126 = #139;
  #125.Representation = #139;

  // --------------------------------------------------
  // Grundwasser – SurfaceFeature an BH01
  // --------------------------------------------------
  #150 = IFCSURFACEFEATURE('GW01',#5,'BH01_Grundwasser',$,$,#151,$,$);
  #151 = IFCLOCALPLACEMENT(#51,#152);
  #152 = IFCAXIS2PLACEMENT3D(#153,#13,#14);
  #153 = IFCCARTESIANPOINT((0.,0.,-2.3));

  // einfache Darstellung als kleiner Kreis (0.5 m)
  #154 = IFCAXIS2PLACEMENT3D(#155,#13,#14);
  #155 = IFCCARTESIANPOINT((0.,0.,-2.3));
  #156 = IFCCIRCLEPROFILEDEF(.AREA.,$,#154,0.5);
  #157 = IFCEXTRUDEDAREASOLID(#156,#154,#73,0.01);
  #158 = IFCSHAPEREPRESENTATION(#10,'Body','SweptSolid',(#157));
  #159 = IFCPRODUCTDEFINITIONSHAPE($,$,(#158));
  #150.Representation = #159;

  // --------------------------------------------------
  // Spatial Containment
  // --------------------------------------------------
  #200 = IFCRELCONTAINEDINSPATIALSTRUCTURE('Rel_Project_Site',#5,$,$,(#30),#20);
  #201 = IFCRELCONTAINEDINSPATIALSTRUCTURE('Rel_Site_Facility',#5,$,$,(#40),#30);
  #202 = IFCRELCONTAINEDINSPATIALSTRUCTURE('Rel_Facility_Borehole',#5,$,$,(#50,#61,#91,#121,#150),#40);

