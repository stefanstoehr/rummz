  #63 = IFCAXIS2PLACEMENT3D(#64,#13,#14);
  #64 = IFCCARTESIANPOINT((0.,0.,0.));

  #65 = IFCGEOTECHNICALSTRATUM('ST01_1',#5,'BH01_Auffüllung',$,$,#66,$,$);

  // Geometrie 1: Bohrzylinder (Kreis, Radius 0.1 m, Höhe 1.2 m)
  #70 = IFCAXIS2PLACEMENT3D(#71,#13,#14);
  #71 = IFCCARTESIANPOINT((0.,0.,0.));
  #72 = IFCCIRCLEPROFILEDEF(.AREA.,$,#70,0.1);
  #73 = IFCDIRECTION((0.,0.,1.));
  #74 = IFCEXTRUDEDAREASOLID(#72,#70,#73,1.2);

  // Geometrie 2: Ausbreitungsvolumen (Rechteck 2x2 m, Höhe 1.2 m)
  #75 = IFCAXIS2PLACEMENT3D(#76,#13,#14);
  #76 = IFCCARTESIANPOINT((0.,0.,0.));
  #77 = IFCRECTANGLEPROFILEDEF(.AREA.,$,#75,2.0,2.0);
  #78 = IFCEXTRUDEDAREASOLID(#77,#75,#73,1.2);

  #79 = IFCSHAPEREPRESENTATION(#10,'Body','SweptSolid',(#74,#78));
  #80 = IFCPRODUCTDEFINITIONSHAPE($,$,(#79));
  #66 = #80; // Representation des Stratums
  #65.Representation = #80;

  // --------------------------------------------------
  // BoreholeRecord 2 – Sand (1.2–4.8 m)
  // --------------------------------------------------
  #90 = IFCBOHOLERECORD('BR01_2',#5,'1.2–4.8m Sand',1.2,4.8);

  #91 = IFCFACILITYPART('FP01_2',#5,'BH01_Schicht_2',$,$,#92,$,$);
  #92 = IFCLOCALPLACEMENT(#51,#93);
  #93 = IFCAXIS2PLACEMENT3D(#94,#13,#14);
  #94 = IFCCARTESIANPOINT((0.,0.,0.));

  #95 = IFCGEOTECHNICALSTRATUM('ST01_2',#5,'BH01_Sand',$,$,#96,$,$);

  // Geometrie 1: Bohrzylinder (1.2–4.8 m → Höhe 3.6 m, Start bei z=1.2)
  #100 = IFCAXIS2PLACEMENT3D(#101,#13,#14);
  #101 = IFCCARTESIANPOINT((0.,0.,1.2));
  #102 = IFCCIRCLEPROFILEDEF(.AREA.,$,#100,0.1);
