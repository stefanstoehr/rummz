ISO-10303-21;
HEADER;
  FILE_DESCRIPTION(('Minimal IFC4.3 ADD2 Borehole Example'),'2;1');
  FILE_NAME('Minimal_Borehole.ifc','2026-01-30T12:00:00',('User'),('Organization'),'','Copilot IFC Generator','');
  FILE_SCHEMA(('IFC4X3_ADD2'));
ENDSEC;

DATA;

#1 = IFCPERSON($,'User',$,$,$,$,$,$);
#2 = IFCORGANIZATION($,'Organization',$,$,$);
#3 = IFCPERSONANDORGANIZATION(#1,#2,$);
#4 = IFCAPPLICATION(#2,'1.0','Copilot IFC Generator','COPILOT_IFC');
#5 = IFCOWNERHISTORY(#3,#4,$,.ADDED.,$,$,$,1);


#10 = IFCSIUNIT(*,.LENGTHUNIT.,$,.METRE.);
#11 = IFCSIUNIT(*,.AREAUNIT.,$,.SQUARE_METRE.);
#12 = IFCSIUNIT(*,.VOLUMEUNIT.,$,.CUBIC_METRE.);
#13 = IFCUNITASSIGNMENT((#10,#11,#12));

#20 = IFCCARTESIANPOINT((0.,0.,0.));
#21 = IFCDIRECTION((0.,0.,1.));
#22 = IFCDIRECTION((1.,0.,0.));
#23 = IFCAXIS2PLACEMENT3D(#20,#21,#22);
#24 = IFCGEOMETRICREPRESENTATIONCONTEXT($,'Model',3,1.E-5,#23,$);

#30 = IFCPROJECT('P1',$,'Minimal Project',$,$,$,$,(#24),#13);


#40 = IFCPROJECTEDCRS('WGS 84 / Pseudo-Mercator','EPSG:3857',$,$,$,$,$);
#41 = IFCMAPCONVERSION(#24,#40,13.406,52.520,34.2,1.,0.);


#50 = IFCCARTESIANPOINT((0.,0.,0.));
#51 = IFCAXIS2PLACEMENT3D(#50,#21,#22);
#52 = IFCLOCALPLACEMENT($,#51);
#53 = IFCSITE('S1',$,'Site',$,$,#52,$,$,.ELEMENT.,$,$,$,$,$);

#54 = IFCRELAGGREGATES('RelProjSite',$,$,$,#30,(#53));

#60 = IFCLOCALPLACEMENT(#52,#51);
#61 = IFCBOREHOLE('BH1',$,'Bohrloch 1',$,$,#60,$,$,$);

#62 = IFCRELAGGREGATES('RelSiteBorehole',$,$,$,#53,(#61));

ENDSEC;
END-ISO-10303-21;
