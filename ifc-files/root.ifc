  // --------------------------------------------------
  #60 = IFCBOHOLERECORD('BR01_1',#5,'0.0–1.2m Auffüllung',0.0,1.2);

  #61 = IFCFACILITYPART('FP01_1',#5,'BH01_Schicht_1',$,$,#62,$,$);
