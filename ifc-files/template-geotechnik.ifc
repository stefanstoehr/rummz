/* Projekt & Site */
#9  = IFCPROJECT('2iROGnohHDQgYa0Nzy9A0_',$,'GeotechProject',$,$,$,$,(#4),#8);
#10 = IFCLOCALPLACEMENT($,#3);
#11 = IFCSITE('1rIGat89X7QxuZL9z$FIuB',$,'Site',$,$,#10,$,$,.ELEMENT.,$,$,$,$,$);
#12 = IFCRELAGGREGATES('2M5Ej0dXL1dhpUsPY$kF5D',$,$,$,#9,(#11));

/* Borehole */
